# ─── Application ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
WORKERS=1
LOG_LEVEL=INFO

# ─── Medical LLM Configuration ───────────────────────────────────────────────
# Supported models: BioMistral-7B, Med42, Meditron, OpenBioLLM
# Download GGUF model and set the path below
MEDICAL_LLM_MODEL=BioMistral-7B-GGUF
MEDICAL_LLM_PATH=./models/BioMistral-7B.Q4_K_M.gguf

# LLM Inference Settings
LLM_CONTEXT_LENGTH=2048
LLM_GPU_LAYERS=0
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_THREADS=4

# ─── Cache Configuration ─────────────────────────────────────────────────────
# Backend: "memory" (default) or "redis"
CACHE_BACKEND=memory
CACHE_TTL=3600

# Redis settings (only if CACHE_BACKEND=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
